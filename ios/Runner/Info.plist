<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
	<dict>
		<key>CADisableMinimumFrameDurationOnPhone</key>
		<true/>
		<!-- Allow the Files app to see documents stored in the app's
	     Documents directory (standard "Open In" sharing). -->
		<key>UIFileSharingEnabled</key>
		<true/>
		<key>LSSupportsOpeningDocumentsInPlace</key>
		<true/>
		<!-- Declare that this app can open markdown files from other apps. -->
		<key>CFBundleDocumentTypes</key>
		<array>
			<dict>
				<key>CFBundleTypeName</key>
				<string>Markdown Document</string>
				<key>CFBundleTypeRole</key>
				<string>Viewer</string>
				<key>LSHandlerRank</key>
				<string>Default</string>
				<!-- Register ONLY the markdown UTI. `public.plain-text`
				     was dropped because it caused the app to appear in the
				     system "Open With" list for every .txt, .csv, and
				     .log file on the device — well beyond the intended
				     scope. Apps that export as
				     `net.daringfireball.markdown` still open here via UTI
				     inheritance. -->
				<key>LSItemContentTypes</key>
				<array>
					<string>net.daringfireball.markdown</string>
				</array>
			</dict>
		</array>
		<!-- Import the markdown UTI so iOS recognises .md / .markdown
	     extensions on devices that do not have another markdown app
	     installed to export the type. -->
		<key>UTImportedTypeDeclarations</key>
		<array>
			<dict>
				<key>UTTypeIdentifier</key>
				<string>net.daringfireball.markdown</string>
				<key>UTTypeDescription</key>
				<string>Markdown Document</string>
				<key>UTTypeConformsTo</key>
				<array>
					<string>public.plain-text</string>
				</array>
				<key>UTTypeTagSpecification</key>
				<dict>
					<key>public.filename-extension</key>
					<array>
						<string>md</string>
						<string>markdown</string>
					</array>
					<key>public.mime-type</key>
					<array>
						<string>text/markdown</string>
						<string>text/x-markdown</string>
					</array>
				</dict>
			</dict>
		</array>
		<key>CFBundleDevelopmentRegion</key>
		<string>$(DEVELOPMENT_LANGUAGE)</string>
		<key>CFBundleDisplayName</key>
		<string>Markdown Viewer</string>
		<key>CFBundleExecutable</key>
		<string>$(EXECUTABLE_NAME)</string>
		<key>CFBundleIdentifier</key>
		<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
		<key>CFBundleInfoDictionaryVersion</key>
		<string>6.0</string>
		<key>CFBundleName</key>
		<string>markdown_viewer</string>
		<key>CFBundlePackageType</key>
		<string>APPL</string>
		<key>CFBundleShortVersionString</key>
		<string>$(FLUTTER_BUILD_NAME)</string>
		<key>CFBundleSignature</key>
		<string>????</string>
		<key>CFBundleVersion</key>
		<string>$(FLUTTER_BUILD_NUMBER)</string>
		<!--
		  Export compliance — declares that the app only uses Apple's
		  standard encryption (HTTPS via URLSession, keychain services,
		  file data protection). Setting this to `false` lets App Store
		  Connect auto-mark each build as "export exempt" so the
		  maintainer does not have to click through the Missing
		  Compliance dialog in TestFlight for every upload. If the app
		  ever ships custom crypto code, flip this to `true` and follow
		  https://developer.apple.com/documentation/security/complying_with_encryption_export_regulations .
		-->
		<key>ITSAppUsesNonExemptEncryption</key>
		<false/>
		<key>LSRequiresIPhoneOS</key>
		<true/>
		<!--
		  Required by App Store Connect static analysis (ITMS-90683)
		  because one or more Flutter plugins bundled with this app —
		  most likely `printing` and/or `share_plus` — link against
		  the PhotoKit framework for their "Save to Photos" share-sheet
		  options. Markdown Viewer does not query the photo library
		  itself, but if a user shares an exported PDF and chooses the
		  system "Save to Photos" action, iOS surfaces this purpose
		  string in the permission prompt. A purpose string is required
		  even when the app never actually triggers that code path.
		-->
		<key>NSPhotoLibraryUsageDescription</key>
		<string>Markdown Viewer may access your photo library if you choose to save an exported document, such as a PDF, back to Photos.</string>
		<key>UIApplicationSceneManifest</key>
		<dict>
			<key>UIApplicationSupportsMultipleScenes</key>
			<false/>
			<key>UISceneConfigurations</key>
			<dict>
				<key>UIWindowSceneSessionRoleApplication</key>
				<array>
					<dict>
						<key>UISceneClassName</key>
						<string>UIWindowScene</string>
						<key>UISceneConfigurationName</key>
						<string>flutter</string>
						<key>UISceneDelegateClassName</key>
						<string>$(PRODUCT_MODULE_NAME).SceneDelegate</string>
						<key>UISceneStoryboardFile</key>
						<string>Main</string>
					</dict>
				</array>
			</dict>
		</dict>
		<key>UIApplicationSupportsIndirectInputEvents</key>
		<true/>
		<key>UILaunchStoryboardName</key>
		<string>LaunchScreen</string>
		<key>UIMainStoryboardFile</key>
		<string>Main</string>
		<key>UISupportedInterfaceOrientations</key>
		<array>
			<string>UIInterfaceOrientationPortrait</string>
			<string>UIInterfaceOrientationLandscapeLeft</string>
			<string>UIInterfaceOrientationLandscapeRight</string>
		</array>
		<key>UISupportedInterfaceOrientations~ipad</key>
		<array>
			<string>UIInterfaceOrientationPortrait</string>
			<string>UIInterfaceOrientationPortraitUpsideDown</string>
			<string>UIInterfaceOrientationLandscapeLeft</string>
			<string>UIInterfaceOrientationLandscapeRight</string>
		</array>
		<key>UIStatusBarHidden</key>
		<false/>
	</dict>
</plist>
