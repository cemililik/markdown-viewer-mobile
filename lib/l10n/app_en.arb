  "@syncCompleted": {
    "description": "Confirmation shown when a repository sync finishes successfully."
  },
  "syncPartial": "Some files could not be downloaded.",
  "@syncPartial": {
    "description": "Warning shown when a sync finishes with partial failures."
  },

  "errorRateLimited": "GitHub rate limit reached. Add a personal access token in Settings or try again later.",
  "@errorRateLimited": {
    "description": "User-facing message when the GitHub API responds with 403 due to rate limiting."
