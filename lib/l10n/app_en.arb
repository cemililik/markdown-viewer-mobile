    "description": "Section header above the list of recently opened markdown documents on the library home screen."
  },
  "libraryRecentClearAll": "Clear all",
  "@libraryRecentClearAll": {
    "description": "Action shown next to the Recent documents section header that wipes the recent list."
  },
  "libraryRecentClearConfirmTitle": "Clear recent documents?",
  "@libraryRecentClearConfirmTitle": {
    "description": "Title of the confirmation dialog before wiping the entire recent documents list."
  },
  "libraryRecentClearConfirmBody": "This removes every entry from the Recent documents list. The files themselves are not deleted.",
  "@libraryRecentClearConfirmBody": {
    "description": "Body of the confirmation dialog before wiping the entire recent documents list."
  },
  "libraryRecentRemove": "Remove from recents",
